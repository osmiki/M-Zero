{
  "manifest_version": 3,
  "name": "Design QA Agent",
  "version": "0.5.5",
  "description": "Extract computed CSS from current page and upload to Design QA Agent.",
  "action": {
    "default_title": "Design QA",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  }
}

